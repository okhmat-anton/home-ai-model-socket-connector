# Server
HOST=0.0.0.0
PORT=10666
BASE_MODEL=llama3

# Auth — модель (Socket.IO)
MODEL_API_KEY=CHANGE_ME_model_key_64_chars_long_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth — пользователь (REST API)
USER_API_KEY=CHANGE_ME_user_key_64_chars_long_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT
SECRET_KEY=CHANGE_ME_secret_key_64_chars_long_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# Timeouts & limits
REQUEST_TIMEOUT=1800
MAX_CONCURRENT_REQUESTS=10

# HTTPS proxy (исходящий режим)
PROXY_PORT=10667
PROXY_USER=proxy
PROXY_PASSWORD=CHANGE_ME_proxy_password
PROXY_ALLOWED_DOMAINS=*
PROXY_MAX_CONNECTIONS=50

# Logging
LOG_LEVEL=INFO
